# HEHA Swipe client env
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Optional Make.com automations
VITE_MAKE_NEW_USER_WEBHOOK=
VITE_MAKE_PARTNER_APPROVAL_WEBHOOK=

# Optional Stripe payment links used directly by the frontend
# One-time $2 SuperSwoop checkout link.
# Use this only until SuperSwoop is moved to a backend Checkout Session.
VITE_STRIPE_SUPERSWOOP_CHECKOUT_URL=

# One-time $1 pre-splash prototype/team support checkout link.
VITE_STRIPE_DOLLAR_SUPPORT_CHECKOUT_URL=

# Supporter subscriptions do NOT use a Vite payment link anymore.
# The custom monthly slider calls the Supabase Edge Function:
# supabase/functions/create-supporter-checkout/index.ts
