VITE_STRIPE_SUPPORTER_CHECKOUT_URL=

# One-time $2 SuperSwoop checkout link.
# Use this only after the app is updated to redirect SuperSwoop clicks to Stripe or a checkout edge function.
VITE_STRIPE_SUPERSWOOP_CHECKOUT_URL=
